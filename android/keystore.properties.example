# QUUKI リリース署名設定サンプル。
# 使い方: このファイルを keystore.properties にコピーし、値を埋める（keystore.properties は gitignore 済み）。
# アップロード鍵(.jks)はリポジトリ外に保管し、storeFile に絶対パスを指定する（Windows はスラッシュ / で可）。
# パスワードは keytool で鍵を作成したときに設定したものを記入する。
storeFile=C:/Users/areaq/keys/quuki-upload.jks
storePassword=
keyAlias=quuki-upload
keyPassword=
